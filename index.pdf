<!-- COURSE PLAN MODAL -->
<div class="modal-overlay" id="courseModal">
  <div class="modal">
    <div class="modal-header">
      <div>
        <h3>📋 خطة مساق تحرير الصوت رقمياً</h3>
        <p>MMED 1205 — الكلية الجامعية للعلوم التطبيقية | 15 أسبوعاً</p>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="week-item">
        <div class="week-num">01</div>
        <div class="week-content">
          <h4>التعريف بالمساق والمادة النظرية</h4>
          <ul class="week-topics">
            <li>تعريف بالمساق وعرض الخطة الدراسية</li>
            <li>عرض المادة النظرية للمساق والمخرجات التعليمية</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">02</div>
        <div class="week-content">
          <h4>مفاهيم المونتاج الصوتي والمصطلحات</h4>
          <ul class="week-topics">
            <li>مفهوم المونتاج الصوتي والهدف منه ومصطلحاته</li>
            <li>وظائف المونتير وبرامج الهندسة الصوتية</li>
            <li>Sample Rate وBit Depth وFade In/Out</li>
            <li>التمييز بين Mono وStereo والصوت المحيطي</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">03</div>
        <div class="week-content">
          <h4>الميكروفونات والتسجيل</h4>
          <ul class="week-topics">
            <li>أنواع الميكروفونات حسب آلية التسجيل والاستخدام</li>
            <li>الأجهزة المستخدمة في تسجيل الصوت</li>
            <li>مشكلات التسجيل وطرق تفاديها — نصائح للتسجيل المنزلي</li>
            <li>مفهوم العزل وتشتيت وتكسير الصوت ومراحل المونتاج</li>
            <li>تنزيل Adobe Audition والتعرف على واجهته</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">04</div>
        <div class="week-content">
          <h4>القوائم والأدوات وإعدادات الصوت</h4>
          <ul class="week-topics">
            <li>شرح القوائم والأدوات وقائمة File</li>
            <li>طريقة التسجيل والمشكلات المحتملة</li>
            <li>أهمية السماعات وضبط إخراج الصوت</li>
            <li>تحويل Stereo إلى Mono وتعديل Sample Rate وBit Depth</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">05</div>
        <div class="week-content">
          <h4>Waveform Editor بالتفصيل</h4>
          <ul class="week-topics">
            <li>شرح واجهة Waveform بشكل مفصل</li>
            <li>حذف الأخطاء من المقطع الصوتي</li>
            <li>التحكم بمستوى الصوت ومستويات السمع المناسبة</li>
            <li>حفظ الملف الصوتي بعد التعديل</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">06</div>
        <div class="week-content">
          <h4>Noise Reduction والـ Fades</h4>
          <ul class="week-topics">
            <li>شرح فلتر Noise Reduction وتنقية الصوت من الضوضاء</li>
            <li>تطبيق Fade In / Fade Out على واجهة Waveform</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">07</div>
        <div class="week-content">
          <h4>Multitrack Session والتسجيل المتعدد</h4>
          <ul class="week-topics">
            <li>شرح واجهة Multitrack بالتفصيل</li>
            <li>تنفيذ مكساج بين الصوت والموسيقى</li>
            <li>شرح Effect Rack وPreset Effect Rack</li>
            <li>التسجيل على واجهة Multitrack</li>
            <li>الهندسة الصوتية والذكاء الاصطناعي في الصوت</li>
          </ul>
        </div>
      </div>
      <div class="week-item" style="border-color:rgba(239,68,68,0.3)">
        <div class="week-num" style="background:rgba(239,68,68,0.15);border-color:rgba(239,68,68,0.3);color:#ef4444">08</div>
        <div class="week-content">
          <h4 style="color:#ef4444">⚡ الامتحان النصفي</h4>
          <ul class="week-topics">
            <li>الامتحان النصفي يغطي الأسابيع 1-7</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">09</div>
        <div class="week-content">
          <h4>الفلاتر من قائمة Filter</h4>
          <ul class="week-topics">
            <li>شرح الفلاتر من قائمة Filter</li>
            <li>خصائص كل فلتر واستخداماته</li>
            <li>استكمال الشرح النظري للفلاتر</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">10</div>
        <div class="week-content">
          <h4>اختبار نظري ومشروع نصفي</h4>
          <ul class="week-topics">
            <li>اختبار نظري واستكمال الفلاتر</li>
            <li>مشروع نصفي: تسجيل وتعديل مقطع صوتي باستخدام المهارات المكتسبة</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">11</div>
        <div class="week-content">
          <h4>التصدير والـ Bus والمؤثرات</h4>
          <ul class="week-topics">
            <li>تصدير الملفات من Multitrack بصيغ مختلفة</li>
            <li>إضافة Effects عبر Bus وEffect Rack</li>
            <li>مصادر المؤثرات والموسيقى المجانية</li>
            <li>تطبيق مؤثرات على مقاطع قرآنية خام</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">12</div>
        <div class="week-content">
          <h4>الفلاتر الخارجية وتقنية 8D</h4>
          <ul class="week-topics">
            <li>إضافة فلاتر خارجية (Plugins) للبرنامج</li>
            <li>تدريبات عملية شاملة: صوت + موسيقى + مؤثرات + انتقالات</li>
            <li>تطبيق تقنية 8D Audio</li>
            <li>عرض مشاريع الطلاب بعد الامتحان النصفي</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">13</div>
        <div class="week-content">
          <h4>الذكاء الاصطناعي في الصوت</h4>
          <ul class="week-topics">
            <li>الذكاء الاصطناعي في الصوت: الإيجابيات والسلبيات</li>
            <li>استخدام أدوات Adobe في إزالة الضوضاء</li>
            <li>تحويل النص إلى صوت (TTS)</li>
            <li>فصل الصوت عن الموسيقى (Stem Separation)</li>
          </ul>
        </div>
      </div>
      <div class="week-item">
        <div class="week-num">14</div>
        <div class="week-content">
          <h4>مواقع العمل والذكاء الاصطناعي التطبيقي</h4>
          <ul class="week-topics">
            <li>أبرز مواقع العمل الحر في مجال الصوت</li>
            <li>تطبيقات الذكاء الاصطناعي في تسجيل ومعالجة الصوت</li>
            <li>تدريبات ومراجعة شاملة</li>
          </ul>
        </div>
      </div>
      <div class="week-item" style="border:none">
        <div class="week-num" style="background:rgba(245,158,11,0.15);border-color:rgba(245,158,11,0.3);color:#f59e0b">15</div>
        <div class="week-content">
          <h4 style="color:#f59e0b">🏆 تسليم المشاريع والامتحان النهائي</h4>
          <ul class="week-topics">
            <li>تسليم وتقييم المشاريع النهائية</li>
            <li>مراجعة شاملة للامتحان النهائي</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Theme Toggle
const body = document.body;
const themeBtn = document.getElementById('themeBtn');
let isLight = false;

themeBtn.addEventListener('click', () => {
  isLight = !isLight;
  body.classList.toggle('light-mode', isLight);
});

// Modal
function openModal() {
  document.getElementById('courseModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('courseModal').classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('courseModal').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closeModal();
});

// Terms filter
function filterTerms(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.term-card').forEach(card => {
    if (cat === 'all' || card.dataset.category === cat) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
}

// Animate on scroll
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) {
      setTimeout(() => {
        entry.target.classList.add('visible');
      }, (entry.target.dataset.delay || 0));
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

// Stagger children within grid parents
document.querySelectorAll('.terms-grid .anim-in, .adobe-grid .anim-in').forEach((el, i) => {
  el.dataset.delay = (i % 4) * 80;
});

document.querySelectorAll('.anim-in').forEach(el => observer.observe(el));
</script>

</body>
</html>