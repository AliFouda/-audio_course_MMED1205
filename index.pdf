              <th style="padding:0.85rem 1.75rem;text-align:center;color:#00a8ff;font-weight:700;border-bottom:1px solid var(--border)">Waveform Editor</th>
              <th style="padding:0.85rem 1.75rem;text-align:center;color:#7c3aed;font-weight:700;border-bottom:1px solid var(--border)">Multitrack Session</th>
            </tr>
