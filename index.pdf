              <td style="padding:0.75rem 1.75rem;text-align:center;color:#7c3aed">لا محدود</td>
            </tr>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05)">
              <td style="padding:0.75rem 1.75rem;color:var(--text-secondary)">التعديل الأصلي</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#00a8ff">يعدل الملف مباشرة</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#7c3aed">غير مدمر (Non-destructive)</td>
            </tr>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05)">
              <td style="padding:0.75rem 1.75rem;color:var(--text-secondary)">الاستخدام الأمثل</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#00a8ff">تنظيف وتحرير ملف واحد</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#7c3aed">إنتاج المكساج الكامل</td>
            </tr>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05)">
              <td style="padding:0.75rem 1.75rem;color:var(--text-secondary)">تطبيق التأثيرات</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#00a8ff">يُطبق داخل الملف</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#7c3aed">عبر Effect Rack / Bus</td>
            </tr>
            <tr>
              <td style="padding:0.75rem 1.75rem;color:var(--text-secondary)">التصدير</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#00a8ff">ملف واحد</td>
              <td style="padding:0.75rem 1.75rem;text-align:center;color:#7c3aed">Mixdown أو عدة صيغ</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

